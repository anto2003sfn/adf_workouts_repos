{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-stracy-studio"
		},
		"AzureBlobStorage1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBlobStorage1'"
		},
		"GoogleBigQuery1_keyFileContent": {
			"type": "secureString",
			"metadata": "Secure string for 'keyFileContent' of 'GoogleBigQuery1'"
		},
		"ls_blob_cust_ingestion_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_blob_cust_ingestion'"
		},
		"ls_mysql_src_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_mysql_src'"
		},
		"ls_mysql_src_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "35.223.80.16"
		},
		"ls_mysql_src_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "telecom_devices"
		},
		"ls_mysql_src_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "inceptez"
		},
		"ls_restapi_src_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://v6.exchangerate-api.com/v6/d2dc0f83029c12073054e204/latest/INR"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-stracy-studio_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureBlobStorage1_connectionString": {
						"value": "[parameters('AzureBlobStorage1_connectionString')]"
					},
					"GoogleBigQuery1_keyFileContent": {
						"value": "[parameters('GoogleBigQuery1_keyFileContent')]"
					},
					"ls_blob_cust_ingestion_connectionString": {
						"value": "[parameters('ls_blob_cust_ingestion_connectionString')]"
					},
					"ls_mysql_src_password": {
						"value": "[parameters('ls_mysql_src_password')]"
					},
					"ls_mysql_src_properties_typeProperties_server": {
						"value": "[parameters('ls_mysql_src_properties_typeProperties_server')]"
					},
					"ls_mysql_src_properties_typeProperties_database": {
						"value": "[parameters('ls_mysql_src_properties_typeProperties_database')]"
					},
					"ls_mysql_src_properties_typeProperties_username": {
						"value": "[parameters('ls_mysql_src_properties_typeProperties_username')]"
					},
					"ls_restapi_src_properties_typeProperties_url": {
						"value": "[parameters('ls_restapi_src_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}